{
  // Workbench / UI
  "workbench.colorTheme": "Atlassian Dark",
  "workbench.iconTheme": "catppuccin-mocha",
  "workbench.sideBar.location": "right",
  "workbench.editor.editorActionsLocation": "hidden",
  // Window / Security
  "window.nativeTabs": true,
  "security.promptForLocalFileProtocolHandling": false,
  "security.workspace.trust.enabled": true,
  "security.workspace.trust.untrustedFiles": "open",
  // Cursor
  "cursor.general.globalCursorIgnoreList": [
    "**/.env",
    "**/.env.*",
    "**/credentials.json",
    "**/secrets.json",
    "**/*.pem",
    "**/id_rsa"
  ],
  // Explorer / Files
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "files.associations": {
    "*.css": "tailwindcss",
    "*.prisma": "prisma"
  },
  // Search
  "search.exclude": {
    "**/dist": true,
    "**/target": true
  },
  // Editor
  "editor.accessibilitySupport": "off",
  "editor.codeActionsOnSave": {
    "source.removeUnusedImports": "always"
  },
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.fontFamily": "'Atlassian Mono', 'JetBrains Mono', '0xProto Nerd Font Mono', 'Geist Mono', Menlo, Monaco, 'Courier New', monospace",
  "editor.lineNumbers": "relative",
  // Terminal
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.scrollback": 15000,
  // Language behavior
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "java.dependency.autoRefresh": false,
  "java.autobuild.enabled": false,
  // Language-specific formatters
  "[java]": {
    "editor.defaultFormatter": "redhat.java"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma"
  },
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml"
  },
  // Extensions
  "gitlens.remotes": [
    {
      "regex": "ssh:\\/\\/(git@stash\\.atlassian\\.com):7997\\/(.+?)(?:\\.git)?$",
      "type": "BitbucketServer",
      "protocol": "https",
      "domain": "https://stash.atlassian.com",
      "username": "pdros"
    }
  ],
  "oxc.typeAware": true,
  "vim.easymotion": true,
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.leader": "<space>",
  "vim.smartRelativeLine": true,
  "vim.useCtrlKeys": true,
  "vim.useSystemClipboard": true,
  "mise.binPath": "/opt/homebrew/bin/mise",
  "gitlens.ai.model": "gitkraken",
  "gitlens.ai.gitkraken.model": "gemini:gemini-2.0-flash",
  "prettier.printWidth": 120,
  // Misc
  "diffEditor.ignoreTrimWhitespace": false,
  "git.openRepositoryInParentFolders": "always",
  "explorer.confirmPasteNative": false,
  "workbench.editor.centeredLayoutAutoResize": false,
  "workbench.editor.centeredLayoutFixedWidth": true,
  "gitlens.views.scm.grouped.views": {
    "commits": true,
    "branches": true,
    "remotes": true,
    "stashes": true,
    "tags": true,
    "worktrees": true,
    "contributors": true,
    "fileHistory": false,
    "repositories": true,
    "searchAndCompare": true,
    "launchpad": false
  },
  "atlascode.rovodev.enabled": true,
  "window.autoDetectColorScheme": false,
  "python.defaultInterpreterPath": "/opt/homebrew/bin/python3",
  "workbench.statusBar.visible": false
}